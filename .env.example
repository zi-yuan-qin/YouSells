# ==============================================
# YouSells 本地开发环境变量模板
# 复制为 .env 后按需修改
# ==============================================

# --- MySQL ---
MYSQL_HOST=localhost
MYSQL_PORT=13306
MYSQL_DATABASE=yousells
MYSQL_USERNAME=root
MYSQL_PASSWORD=root

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_PASSWORD=

# --- JWT（生产环境必须设置为强随机字符串，至少 256 bit） ---
JWT_SECRET=yousells-local-dev-secret-key-change-in-production

# --- Server ---
SERVER_PORT=8080

# --- Frontend ---
WEB_PORT=5173
WEB_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VITE_API_BASE_URL=/api

# --- AI / LLM（生产环境必须设置，开发环境可用 mock 模式） ---
AI_LLM_ENDPOINT=https://api.openai.com
AI_LLM_API_KEY=sk-your-api-key
AI_LLM_MODEL=gpt-4o
AI_LLM_TEMPERATURE=0.3
AI_EMBEDDING_ENDPOINT=https://api.openai.com
AI_EMBEDDING_API_KEY=sk-your-api-key
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_MOCK_ENABLED=true

# --- Qdrant 向量数据库 ---
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_API_KEY=
