<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yousells.modules.followup.mapper.FollowUpMapper">

    <resultMap id="followUpMap" type="com.yousells.modules.followup.entity.FollowUpEntity">
        <id property="id" column="id"/>
        <result property="customerId" column="customer_id"/>
        <result property="userId" column="user_id"/>
        <result property="progress" column="progress"/>
        <result property="content" column="content"/>
        <result property="feedback" column="feedback"/>
        <result property="nextAction" column="next_action"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="isDeleted" column="is_deleted"/>
    </resultMap>

    <select id="pageFollowUps" resultMap="followUpMap">
        SELECT fu.*
        FROM customer_follow_ups fu
        JOIN customers c ON fu.customer_id = c.id AND c.is_deleted = 0
        WHERE fu.is_deleted = 0
        <if test="customerId != null">
            AND fu.customer_id = #{customerId}
        </if>
        <if test="visibleUserIds != null and visibleUserIds.size() > 0">
            AND (c.owner_user_id IN
            <foreach collection="visibleUserIds" item="id" open="(" close=")" separator=",">
                #{id}
            </foreach>
            OR c.inviter_user_id IN
            <foreach collection="visibleUserIds" item="id" open="(" close=")" separator=",">
                #{id}
            </foreach>)
        </if>
        ORDER BY fu.created_at DESC
    </select>

    <select id="selectUserDisplayNames" resultType="com.yousells.modules.followup.mapper.FollowUpMapper$UserDisplayName">
        SELECT id AS userId, COALESCE(real_name, display_name) AS displayName
        FROM users
        WHERE id IN
        <foreach collection="userIds" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
        AND is_deleted = 0
    </select>

</mapper>
