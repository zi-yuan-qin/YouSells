<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yousells.modules.customer.mapper.AiInsightCacheMapper">

    <resultMap id="cacheMap" type="com.yousells.modules.customer.entity.AiInsightCache">
        <id property="id" column="id"/>
        <result property="customerId" column="customer_id"/>
        <result property="insightJson" column="insight_json"/>
        <result property="generatedAt" column="generated_at"/>
        <result property="expiresAt" column="expires_at"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectValidByCustomerId" resultMap="cacheMap">
        SELECT *
        FROM ai_insight_cache
        WHERE customer_id = #{customerId}
          AND expires_at > NOW()
        LIMIT 1
    </select>

    <delete id="deleteByCustomerId">
        DELETE FROM ai_insight_cache
        WHERE customer_id = #{customerId}
    </delete>

</mapper>
