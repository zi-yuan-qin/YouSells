<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yousells.modules.customer.mapper.CustomerMapper">

    <resultMap id="customerMap" type="com.yousells.modules.customer.entity.CustomerEntity">
        <id property="id" column="id"/>
        <result property="realName" column="real_name"/>
        <result property="grade" column="grade"/>
        <result property="major" column="major"/>
        <result property="className" column="class_name"/>
        <result property="inviterUserId" column="inviter_user_id"/>
        <result property="ownerUserId" column="owner_user_id"/>
        <result property="progress" column="progress"/>
        <result property="intent" column="intent"/>
        <result property="inviterNote" column="inviter_note"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="createdBy" column="created_by"/>
        <result property="updatedBy" column="updated_by"/>
        <result property="isDeleted" column="is_deleted"/>
    </resultMap>

    <sql id="customerQueryCondition">
        WHERE c.is_deleted = 0
        <if test="keyword != null and keyword != ''">
            AND c.real_name LIKE CONCAT('%', #{keyword}, '%')
        </if>
        <if test="grade != null and grade != ''">
            AND c.grade = #{grade}
        </if>
        <if test="major != null and major != ''">
            AND c.major LIKE CONCAT('%', #{major}, '%')
        </if>
        <if test="progress != null and progress != ''">
            AND c.progress = #{progress}
        </if>
        <if test="intent != null and intent != ''">
            AND c.intent = #{intent}
        </if>
        <if test="ownerUserId != null">
            AND c.owner_user_id = #{ownerUserId}
        </if>
        <if test="visibleUserIds != null and visibleUserIds.size() > 0">
            AND (c.inviter_user_id IN
            <foreach collection="visibleUserIds" item="uid" open="(" close=")" separator=",">
                #{uid}
            </foreach>
            OR c.owner_user_id IN
            <foreach collection="visibleUserIds" item="uid" open="(" close=")" separator=",">
                #{uid}
            </foreach>)
        </if>
    </sql>

    <select id="pageCustomers" resultMap="customerMap">
        SELECT c.*
        FROM customers c
        <include refid="customerQueryCondition"/>
        ORDER BY c.updated_at DESC
    </select>

    <select id="listCustomers" resultMap="customerMap">
        SELECT c.*
        FROM customers c
        <include refid="customerQueryCondition"/>
        ORDER BY c.updated_at DESC
    </select>

    <select id="selectUserDisplayNames" resultType="com.yousells.modules.customer.mapper.CustomerMapper$UserDisplayName">
        SELECT id AS userId, COALESCE(real_name, display_name) AS displayName
        FROM users
        WHERE id IN
        <foreach collection="userIds" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
        AND is_deleted = 0
    </select>

    <select id="selectSilentCustomers" resultMap="customerMap">
        SELECT c.*
        FROM customers c
        WHERE c.is_deleted = 0
          AND NOT EXISTS (
              SELECT 1 FROM customer_follow_ups f
              WHERE f.customer_id = c.id
                AND f.is_deleted = 0
                AND f.created_at &gt; #{deadline}
          )
          AND c.created_at &lt; #{deadline}
          <if test="visibleUserIds != null and visibleUserIds.size() &gt; 0">
            AND (c.owner_user_id IN
              <foreach collection="visibleUserIds" item="id" open="(" separator="," close=")">#{id}</foreach>
              OR c.inviter_user_id IN
              <foreach collection="visibleUserIds" item="id" open="(" separator="," close=")">#{id}</foreach>
            )
          </if>
    </select>

</mapper>
